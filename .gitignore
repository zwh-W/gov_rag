# ==========================================
# 1. Python 缓存与编译文件 (必须屏蔽，否则每次运行都会变)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# 2. 虚拟环境 (绝不能提交，太大了，而且团队成员系统不同)
# ==========================================
venv/
.venv/
env/
rag_env/
Include/
Lib/
Scripts/

# ==========================================
# 3. 环境变量与机密配置 (极其重要！防止 API Key 泄露)
# ==========================================
.env
.env.*
!.env.example  # 允许提交模板文件，让别人知道需要配哪些环境变量

# ==========================================
# 4. 本地数据库文件 (防止把测试数据覆盖给别人)
# ==========================================
*.db
*.sqlite3
rag.db

# ==========================================
# 5. 用户上传的文件 (防止泄露业务机密或把仓库撑爆)
# ==========================================
uploads/
upload_files/
data/

# ==========================================
# 6. 运行日志
# ==========================================
logs/
*.log

# ==========================================
# 7. AI 模型权重文件 (极其巨大，坚决不能提交到 Git)
# ==========================================
models/
*.bin
*.pt
*.safetensors
*.onnx
*.h5
*.msgpack

# ==========================================
# 8. IDE 与编辑器配置文件 (你用的是 PyCharm)
# ==========================================
.idea/
.vscode/
*.swp
*.swo

# ==========================================
# 9. 操作系统生成的垃圾文件
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# 10. 测试与覆盖率报告
# ==========================================
.pytest_cache/
.coverage
htmlcov/
# ==========================================
# 11. 压缩包与大型二进制文件 (防止提交 IK 插件 zip 等文件)
# ==========================================
*.zip
*.tar.gz
*.rar
*.7z